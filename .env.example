# =============================================================================
# MemOS v2.0 - 环境配置示例
# 复制为 .env 文件并填入实际值
# =============================================================================

# =============================================================================
# LLM 双模型配置 (OpenAI Compatible)
# =============================================================================

# -----------------------------------------------------------------------------
# System Model (Fast) - 用于路由、提取、批处理、感知
# 推荐: Gemini-2.5-Flash / DeepSeek-V3 / gpt-4o-mini
# 要求: 需支持 Vision (多模态)
# -----------------------------------------------------------------------------
# Google AI Studio (Gemini) - 推荐，中国大陆可访问
SYSTEM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
SYSTEM_API_KEY=your_gemini_api_key_here
SYSTEM_MODEL=gemini-2.5-flash-preview-05-20
SYSTEM_TEMPERATURE=0.3

# 或者: 硅基流动 (SiliconFlow) - 国内友好的大模型平台
# SYSTEM_BASE_URL=https://api.siliconflow.cn/v1
# SYSTEM_API_KEY=your_siliconflow_key_here
# SYSTEM_MODEL=deepseek-ai/DeepSeek-V3
# SYSTEM_TEMPERATURE=0.3

# 或者: DeepSeek 官方
# SYSTEM_BASE_URL=https://api.deepseek.com/v1
# SYSTEM_API_KEY=your_deepseek_key_here
# SYSTEM_MODEL=deepseek-chat
# SYSTEM_TEMPERATURE=0.3

# -----------------------------------------------------------------------------
# User Model (Smart) - 用于最终生成、深度推理
# 推荐: Kimi k2.5 / Claude Sonnet / GPT-4o
# -----------------------------------------------------------------------------
# Moonshot AI (Kimi) - 推荐，中文表现优秀
USER_BASE_URL=https://api.moonshot.cn/v1
USER_API_KEY=your_moonshot_key_here
USER_MODEL=kimi-k2-5
USER_TEMPERATURE=0.7

# 或者: DeepSeek
# USER_BASE_URL=https://api.deepseek.com/v1
# USER_API_KEY=your_deepseek_key_here
# USER_MODEL=deepseek-reasoner
# USER_TEMPERATURE=0.7

# 或者: OpenAI
# USER_BASE_URL=https://api.openai.com/v1
# USER_API_KEY=your_openai_key_here
# USER_MODEL=gpt-4o
# USER_TEMPERATURE=0.7

# =============================================================================
# Supabase 数据库配置
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# =============================================================================
# 可选: 其他服务配置
# =============================================================================

# 音频转录 (Whisper / 阿里云 / 讯飞)
# WHISPER_API_KEY=your_key_here
# ALIYUN_ACCESS_KEY_ID=your_key
# ALIYUN_ACCESS_KEY_SECRET=your_secret

# 文档解析 (Unstructured / 阿里云文档解析)
# UNSTRUCTURED_API_KEY=your_key_here

# 向量维度 (根据 embedding 模型调整)
EMBEDDING_DIMENSION=1536

# =============================================================================
# 应用配置
# =============================================================================
APP_ENV=development
LOG_LEVEL=INFO

# 批处理配置
BATCH_SIZE=100
BATCH_INTERVAL_SECONDS=300
