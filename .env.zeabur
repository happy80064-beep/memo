# Zeabur 环境变量模板
# 部署后在 Zeabur 控制台填入这些值

# System Model (Gemini)
SYSTEM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
SYSTEM_API_KEY=
SYSTEM_MODEL=gemini-2.5-flash
SYSTEM_TEMPERATURE=0.3

# User Model (Moonshot/Kimi)
USER_BASE_URL=https://api.moonshot.cn/v1
USER_API_KEY=
USER_MODEL=kimi-k2-5
USER_TEMPERATURE=0.7

# Supabase Database
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App Settings
APP_ENV=production
LOG_LEVEL=INFO

# Schedule Settings
SCHEDULE_EXTRACTOR_MINUTES=10
SCHEDULE_COMPILER_MINUTES=30
