# 飞书应用配置
# 1. 在飞书开放平台 https://open.feishu.cn/app 创建企业自建应用
# 2. 获取以下凭证并填入环境变量

# 飞书应用凭证（必须）
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书事件订阅验证（可选，建议配置）
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxx

# 飞书消息加密密钥（可选，启用加密时需要）
FEISHU_ENCRYPT_KEY=

# MemOS原有配置
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxxxxxxxxxx
SYSTEM_API_KEY=xxxxxxxxxxxxxxxx
SYSTEM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
SYSTEM_MODEL=gemini-2.5-flash
USER_API_KEY=xxxxxxxxxxxxxxxx
USER_BASE_URL=https://api.moonshot.cn/v1
USER_MODEL=kimi-k2-5
