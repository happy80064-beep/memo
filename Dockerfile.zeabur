# Zeabur Dockerfile
# 合并提取器和编译器到一个容器，内部调度运行

FROM python:3.11-slim

WORKDIR /app

# 安装依赖（完整版）
RUN pip install --no-cache-dir \
    supabase>=2.0.0 \
    langchain>=0.3.0 \
    langchain-openai>=0.2.0 \
    python-dotenv>=1.0.0 \
    requests>=2.31.0 \
    pydantic>=2.0.0

# 复制应用代码（不包括 .env）
COPY *.py .

# 注意：.env 文件不复制，通过 Zeabur 环境变量配置
# 容器启动时运行内置调度器
CMD ["python", "zeabur-scheduler.py"]
